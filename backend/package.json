{
  "name": "aayurvani-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "description": "Secure deterministic backend for the Aayurvani Flutter application.",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
